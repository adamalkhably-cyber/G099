// 1. Import sqlite3
const sqlite3 = require('sqlite3').verbose();

// 2. Connect to your database file
let db = new sqlite3.Database('./db/closet.db', (err) => {
  if (err) {
    console.error(err.message);
  }
  console.log('Connected to the closet database.');
});

// 3. Insert data into clothes table
db.run(
  `INSERT INTO clothes (user_id, name, category, image_path) VALUES (?, ?, ?, ?)`,
  [1, "Blue Jeans", "Jeans", "/images/bluejeans.jpg"],
  function(err) {
    if (err) {
      return console.error(err.message);
    }
    console.log(`A row has been inserted with rowid ${this.lastID}`);
  }
);

// 4. Close the connection when done
db.close((err) => {
  if (err) {
    console.error(err.message);
  }
  console.log('Closed the database connection.');
});
